// prisma/schema.prisma

generator client {
  provider = "prisma-client-js" // تم تصحيح المزود
  // تمت إزالة مسار التوليد المخصص للالتزام بالمعايير القياسية
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Domain Models (تمثيل الجداول والعلاقات)
// -----------------------------------------------------------------------------

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)

  // علاقة One-to-Many
  tasks     Task[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("users") // اسم الجدول الفعلي في قاعدة البيانات
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  title       String     @db.VarChar(255)
  description String?    @db.Text
  status      TaskStatus @default(OPEN)

  // المفتاح الأجنبي وتفعيل الحذف المتسلسل (Cascade Delete)
  userId      String     @map("user_id") @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(6)

  @@map("tasks")
}
